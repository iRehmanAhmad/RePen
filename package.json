{
  "name": "repen",
  "version": "1.0.0",
  "description": "Free Windows screen annotation and presentation overlay tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node scripts/verify-js-syntax.js && node scripts/verify-dom-ids.js && node scripts/verify-ipc-contract.js && node scripts/verify-tool-state.js && node scripts/verify-scene-store-separation.js && node scripts/verify-eraser-geometry.js && node scripts/verify-dialog-routing.js",
    "test:unit": "vitest run",
    "postinstall": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks",
    "graphify:update": "graphify update .",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "ts:check": "tsc --noEmit",
    "dist": "npx electron-builder --win"
  },
  "build": {
    "appId": "com.reman.repen",
    "productName": "RePen",
    "compression": "maximum",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/renderer/assets/app-icon.png"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [
    "annotation",
    "screen",
    "overlay",
    "presenter",
    "whiteboard",
    "screen-annotation",
    "presentation-tool",
    "screen-drawing",
    "windows",
    "electron"
  ],
  "author": "Rehman Ahmad",
  "license": "ISC",
  "homepage": "https://rehmanahmad.pro/software/repen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iRehmanAhmad/RePen.git"
  },
  "bugs": {
    "url": "https://github.com/iRehmanAhmad/RePen/issues"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
